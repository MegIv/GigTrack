<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="?android:attr/colorBackgroundFloating">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <View
            android:id="@+id/view_indicator"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:backgroundTint="@color/accent_gold"
            android:alpha="0.15"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_media_play"
            app:tint="@color/accent_gold"
            app:layout_constraintBottom_toBottomOf="@+id/view_indicator"
            app:layout_constraintEnd_toEndOf="@+id/view_indicator"
            app:layout_constraintStart_toStartOf="@+id/view_indicator"
            app:layout_constraintTop_toTopOf="@+id/view_indicator" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="12dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/layout_badge_duration"
            app:layout_constraintStart_toEndOf="@+id/view_indicator"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_history_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Song Title"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/tv_history_artist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Artist Name"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/tv_history_note"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Note: Focus on solo section part"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="13sp"
                android:textStyle="italic"
                android:ellipsize="end"
                android:maxLines="2" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_badge_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@android:drawable/toast_frame"
            android:backgroundTint="@color/primary_studio"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:gravity="center"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_history_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="05:12"
                android:textColor="@color/accent_gold"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>